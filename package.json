{
  "name": "astros-ecount-mcp",
  "version": "1.0.0",
  "description": "ECOUNT ERP Open API MCP Server",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node build/index.js",
    "test": "vitest run",
