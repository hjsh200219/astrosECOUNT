{
  "name": "astros-ecount-mcp",
  "version": "1.0.0",
  "description": "ECOUNT ERP Open API MCP Server",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "astros-ecount-mcp": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify-docs": "tsx scripts/verify-docs.ts",
    "prelint": "tsx scripts/verify-docs.ts",
    "lint": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "pdf-lib": "^1.17.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
